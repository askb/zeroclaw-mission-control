# ZeroClaw Mission Control — Environment Template
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Or run the setup script to auto-generate internal tokens:
#   ../scripts/setup.sh
#
# ⚠️  NEVER commit .env — it is gitignored

# ─── API Provider Keys ───────────────────────────────────────────
# Required: At least one LLM provider key
# Option 1: OpenRouter (RECOMMENDED — single key for all models)
#   Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# Option 2: Direct provider keys (optional, if you have them)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BRAVE_API_KEY=

# Option 3: Google Gemini (free tier)
#   Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ─── Internal Tokens (auto-generated by setup.sh) ────────────────
ZEROCLAW_GATEWAY_TOKEN=REPLACE_WITH_RANDOM_HEX_64
REDIS_PASSWORD=REPLACE_WITH_RANDOM_BASE64_32

# ─── Service Configuration ───────────────────────────────────────
# 127.0.0.1 = local only (secure default), 0.0.0.0 = LAN accessible
GATEWAY_BIND_HOST=127.0.0.1
DASHBOARD_BIND_HOST=127.0.0.1

# Ports
GATEWAY_PORT=18789
DASHBOARD_PORT=4000

# ─── Home Assistant (read-only, local network) ──────────────────
# Token from a restricted non-admin HA user (local access only)
# Get token: HA → Profile → Long-Lived Access Tokens
HA_URL=http://192.168.1.176:8123
HA_TOKEN=PASTE_YOUR_ZEROCLAW_RO_TOKEN_HERE

# ─── Developer Dashboard (read-only tokens) ─────────────────────
# Fine-grained GitHub PAT with READ-ONLY access for reviews/PRs
GITHUB_RO_TOKEN=
GERRIT_HTTP_USER=
GERRIT_HTTP_PASS=

# ─── PopeBot Job Runner (WRITE access — scoped) ─────────────────
# Fine-grained GitHub PAT with Contents + Pull Requests write access
# Scoped to ONLY repos listed in config/allowed-repos.json
# Create at: https://github.com/settings/personal-access-tokens/new
#   → Repository access: Only select repositories (your repos)
#   → Permissions: Contents (Read & Write), Pull requests (Read & Write)
GITHUB_PAT=
GITHUB_USER=askb
TARGET_REPO=askb/zeroclaw-mission-control
