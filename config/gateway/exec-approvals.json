{
  "version": 1,
  "defaults": {
    "mode": "allowlist"
  },
  "agents": {
    "*": {
      "denyPatterns": [
        "git push --force*",
        "git push -f*",
        "git push --force-with-lease*",
        "git push * --force*",
        "git push * -f*",
        "git push origin main*",
        "git push origin master*",
        "git push * main*",
        "git push * master*",
        "git merge *",
        "git rebase *",
        "git reset --hard*",
        "gh pr merge*",
        "gh repo delete*",
        "gh repo create*",
        "gh repo edit*",
        "gh repo fork*",
        "sudo *",
        "su *",
        "rm -rf /*",
        "rm -rf ~/*",
        "rm -rf .*",
        "pkill *",
        "killall *",
        "kill -9 *",
        "chmod 777 *",
        "chown *",
        "iptables *",
        "ufw *",
        "firewall-cmd *",
        "systemctl *",
        "service *",
        "docker compose up*",
        "docker compose down*",
        "docker compose restart*",
        "docker compose stop*",
        "docker compose rm*",
        "docker compose pull*",
        "docker start *",
        "docker stop *",
        "docker restart *",
        "docker rm *",
        "docker volume rm *",
        "docker volume prune*",
        "docker system prune*",
        "docker image rm*",
        "docker rmi *",
        "docker run *",
        "docker exec * rm *",
        "docker exec * sh -c *rm*",
        "curl * | bash",
        "curl * | sh",
        "wget * | bash",
        "wget * | sh",
        "eval *",
        "env",
        "printenv",
        "set",
        "export *",
        "echo *API_KEY*",
        "echo *SECRET*",
        "echo *TOKEN*",
        "echo *PASSWORD*",
        "echo *CREDENTIAL*",
        "cat /proc/*/environ*",
        "cat */.env",
        "cat */.env.*",
        "cat *.key",
        "cat *.pem",
        "cat *id_rsa*",
        "cat *id_ed25519*",
        "n8n *",
        "hass-cli * call_service*",
        "hass-cli * edit*",
        "hass-cli * delete*"
      ],
      "allowPatterns": [
        "git status*",
        "git --no-pager *",
        "git log *",
        "git diff *",
        "git branch *",
        "git checkout -b zeroclaw/*",
        "git checkout -b feat/*",
        "git checkout -b fix/*",
        "git checkout -b docs/*",
        "git checkout -b hotfix/*",
        "git add *",
        "git commit -s *",
        "git push origin zeroclaw/*",
        "git push origin feat/*",
        "git push origin fix/*",
        "git push origin docs/*",
        "git push origin hotfix/*",
        "git remote *",
        "git rev-parse *",
        "git show *",
        "git clone *askb/*",
        "gh pr create*",
        "gh pr list*",
        "gh pr view*",
        "gh pr diff*",
        "gh pr checks*",
        "gh pr comment*",
        "gh issue list*",
        "gh issue view*",
        "gh issue comment*",
        "gh repo view *askb/*",
        "gh repo clone *askb/*",
        "gh run list*",
        "gh run view*",
        "gh api *",
        "gh search *",
        "docker stats*",
        "docker ps*",
        "docker logs*",
        "docker inspect*",
        "docker compose -f * ps*",
        "docker compose -f * logs*",
        "docker exec zeroclaw-gateway openclaw *",
        "ls *",
        "cat *",
        "head *",
        "tail *",
        "grep *",
        "find *",
        "wc *",
        "echo *",
        "pwd",
        "whoami",
        "date",
        "uptime",
        "free *",
        "df *",
        "du *",
        "pre-commit *",
        "shellcheck *",
        "yamllint *",
        "actionlint *",
        "python3 *",
        "pip list*",
        "node --version*",
        "npm list*",
        "jq *",
        "curl -s *",
        "wget -q *"
      ]
    }
  }
}
